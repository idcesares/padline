{
  "name": "padline",
  "private": true,
  "version": "0.1.0",
  "description": "URL-first, no-account, real-time collaborative pads. A modern Dontpad successor.",
  "author": {
    "name": "Isaac D'Césares",
    "email": "isaac.dcesares@gmail.com",
    "url": "https://github.com/idcesares"
  },
  "license": "MIT",
  "homepage": "https://padline.dcesares.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idcesares/padline.git"
  },
  "bugs": "https://github.com/idcesares/padline/issues",
  "keywords": [
    "collaborative-editing",
    "yjs",
    "crdt",
    "cloudflare-workers",
    "durable-objects",
    "blocknote",
    "dontpad",
    "notepad",
    "real-time"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "tsc -p test/tsconfig.json --noEmit && vitest run --max-workers=1 --no-isolate",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy -c dist/padline/wrangler.json",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@blocknote/shadcn": "^0.51.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.30",
    "lucide-react": "^1.24.0",
    "partyserver": "^0.5.8",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "tailwind-merge": "^3.6.0",
    "y-indexeddb": "^9.0.12",
    "y-partyserver": "^2.2.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260708.1": true,
    "workerd@1.20260714.1": true
  }
}
